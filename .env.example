# Database
POSTGRES_USER=scilibrarian
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scilibrarian

# Auth
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI Model API Keys ──────────────────────────────────────────────────────────
# Add the key(s) for the provider(s) you want to use.
# At least one is required. Claude (Anthropic) is the default.

# Anthropic (Claude Sonnet/Opus/Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, GPT-4-turbo)
OPENAI_API_KEY=sk-...

# Google (Gemini 1.5 Pro/Flash)
GEMINI_API_KEY=...

# ── Local / Self-hosted Models ─────────────────────────────────────────────────
# Ollama — two options:
#
# Option A (recommended): Run Ollama inside Docker Compose
#   docker-compose --profile ollama up --build
#   docker-compose exec ollama ollama pull llama3.2
#   Leave OLLAMA_BASE_URL as default (http://ollama:11434)
#
# Option B: Use Ollama running on your host machine
#   Set OLLAMA_BASE_URL=http://localhost:11434
#   (on Linux, may need: http://172.17.0.1:11434)
OLLAMA_BASE_URL=http://ollama:11434

# vLLM: OpenAI-compatible API for self-hosted models
# Set this to your vLLM server URL and select "openai/your-model" in the UI
VLLM_BASE_URL=

# ── Search Sources (all free, API keys are optional) ──────────────────────────
# Semantic Scholar: optional key increases rate limit (100 req/sec vs 1 req/sec)
# Get key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex: add your email to use the "polite pool" (much higher rate limits)
# No account needed — just your email address
OPENALEX_EMAIL=your@email.com

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=50
