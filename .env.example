# Database
POSTGRES_USER=scilibrarian
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scilibrarian

# Auth
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI Model API Keys ──────────────────────────────────────────────────────────
# Add the key(s) for the provider(s) you want to use.
# At least one is required. Claude (Anthropic) is the default.

# Anthropic (Claude Sonnet/Opus/Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, GPT-4-turbo)
OPENAI_API_KEY=sk-...

# Google (Gemini 1.5 Pro/Flash)
GEMINI_API_KEY=...

# ── Local / Self-hosted Models ─────────────────────────────────────────────────
# Ollama — two options:
#
# Option A (recommended): Run Ollama inside Docker Compose
#   docker-compose --profile ollama up --build
#   docker-compose exec ollama ollama pull llama3.2
#   Leave OLLAMA_BASE_URL as default (http://ollama:11434)
#
# Option B: Use Ollama running on your host machine
#   Set OLLAMA_BASE_URL=http://host.docker.internal:11434
#   (on Linux, may need: http://172.17.0.1:11434)
OLLAMA_BASE_URL=http://ollama:11434

# vLLM: OpenAI-compatible API for self-hosted models
# Set this to your vLLM server URL and select "openai/your-model" in the UI
VLLM_BASE_URL=

# ── Search Sources (all free, API keys are optional) ──────────────────────────
# Semantic Scholar: optional key increases rate limit (100 req/sec vs 1 req/sec)
# Get key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex: add your email to use the "polite pool" (much higher rate limits)
# No account needed — just your email address
OPENALEX_EMAIL=your@email.com

# Brave Search API: recommended for reliable web search in monitors
# Free tier: 2000 queries/month, no credit card, sign up at https://api.search.brave.com/
# Without this key, web search uses DuckDuckGo which rate-limits aggressively from
# server/Docker environments. Brave is more reliable for production use.
BRAVE_SEARCH_API_KEY=

# ── Email ingestion — submit PDFs & URLs by emailing Alexandria ───────────────
# Create a dedicated inbox, set credentials below, and Alexandria will
# check it every INGEST_CHECK_INTERVAL_MINUTES and file new submissions.
#
# Gmail setup:
#   1. Create a Gmail alias or dedicated account
#   2. Enable 2FA → generate App Password at myaccount.google.com/apppasswords
#   3. Set INGEST_IMAP_HOST=imap.gmail.com, PORT=993, SSL=true
#
INGEST_EMAIL_ENABLED=false
INGEST_IMAP_HOST=imap.gmail.com
INGEST_IMAP_PORT=993
INGEST_IMAP_USERNAME=ingest@yourdomain.com
INGEST_IMAP_PASSWORD=your-app-password
INGEST_IMAP_FOLDER=INBOX
INGEST_IMAP_SSL=true
INGEST_DEFAULT_PROJECT_ID=1
INGEST_CHECK_INTERVAL_MINUTES=10

# ── SMTP (digest emails and ingestion confirmations) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alexandria@scilibrarian.local
SMTP_TLS=true

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=50
